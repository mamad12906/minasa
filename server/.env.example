# Minasa server environment template.
# Copy to .env and fill in real values; .env is gitignored.

# PostgreSQL connection string. SSL is enabled automatically when
# NODE_ENV=production.
DATABASE_URL=postgresql://user:password@localhost:5432/minasa

# JWT signing secret. The server refuses to start if unset. Use a long,
# random string and rotate by issuing a fresh secret + invalidating tokens.
JWT_SECRET=change-me-to-a-random-string-at-least-32-chars

# API key required on every /api/* request. Comma-separated list allows
# rotation without downtime: deploy with both old and new keys, switch
# clients, then drop the old key.
API_KEY=key1,key2

# Optional CORS allowlist (comma-separated origins). Empty = reflect any
# origin (fine for desktop/mobile clients with no Origin header).
ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# Server port. Default 3000.
PORT=3000

# pg pool size. Default 20. Increase under load if /health shows queue.
PG_POOL_MAX=20

# Where mobile-update.ts looks for APKs + version.json. Production VPS
# expects this dir; without it, the endpoint quietly returns version=1.0.0
# and the in-app updater never triggers.
UPDATES_DIR=/opt/minasa-server/updates

# Set to "production" to enable Postgres SSL (rejectUnauthorized:false).
NODE_ENV=production
